# FractalClaw Environment Configuration
# Copy this file to .env and fill in your values

# ===========================================
# Default Model Configuration
# ===========================================
# Default provider and model (used when no task-type-specific model is configured)
DEFAULT_PROVIDER=openai
DEFAULT_MODEL=gpt-4

# ===========================================
# Task-Specific Model Configuration (optional)
# ===========================================
# Configure different models for different task types.
# Format: provider/model_name (e.g., deepseek/deepseek-coder)
# If only model_name is provided (no /), DEFAULT_PROVIDER will be used.
# Leave commented out to use DEFAULT_MODEL for all tasks.

# Deep reasoning, planning, coordination (requires strong reasoning ability)
# MODEL_REASONING=deepseek/deepseek-chat

# Code generation, debugging, testing (requires strong coding ability)
# MODEL_CODE=deepseek/deepseek-coder

# Information search, analysis, research (requires strong analysis ability)
# MODEL_RESEARCH=openai/gpt-4

# Simple conversation, Q&A (requires fast response, low cost)
# MODEL_CHAT=openai/gpt-3.5-turbo

# Content creation, translation, creative writing (requires strong creativity)
# MODEL_WRITING=anthropic/claude-3-sonnet

# ===========================================
# OpenAI Configuration
# ===========================================
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_API_BASE=https://api.openai.com/v1
# Available models: gpt-4, gpt-4-turbo, gpt-4-vision-preview, gpt-3.5-turbo

# ===========================================
# Anthropic Configuration
# ===========================================
# ANTHROPIC_API_KEY=your-anthropic-api-key-here
# ANTHROPIC_BASE_URL=https://api.anthropic.com
# Available models: claude-3-opus, claude-3-sonnet, claude-3-haiku

# ===========================================
# DeepSeek Configuration
# ===========================================
# DEEPSEEK_API_KEY=your-deepseek-api-key-here
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
# Available models: deepseek-coder, deepseek-chat

# ===========================================
# Zhipu AI (GLM) Configuration
# ===========================================
# ZHIPU_API_KEY=your-zhipu-api-key-here
# ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4
# Available models: glm-4, glm-3-turbo

# ===========================================
# Alibaba Qwen Configuration
# ===========================================
# DASHSCOPE_API_KEY=your-dashscope-api-key-here
# DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/api/v1
# Available models: qwen-max, qwen-turbo

# ===========================================
# Moonshot Configuration
# ===========================================
# MOONSHOT_API_KEY=your-moonshot-api-key-here
# MOONSHOT_BASE_URL=https://api.moonshot.cn/v1
# Available models: moonshot-v1-auto, moonshot-v1-8k, moonshot-v1-32k

# ===========================================
# Ollama Configuration (Local)
# ===========================================
# OLLAMA_BASE_URL=http://localhost:11434
# Available models: llama2, mistral, codellama, etc.

# ===========================================
# Third-party / Custom OpenAI-Compatible API
# ===========================================
# For APIs that are OpenAI-compatible but not official OpenAI
# Example: Azure OpenAI, local LLM servers, proxy services, etc.
# OPENAI_API_KEY=your-custom-api-key-here
# OPENAI_API_BASE=https://your-custom-endpoint.com/v1
# DEFAULT_PROVIDER=other
# DEFAULT_MODEL=your-model-name

# ===========================================
# Tavily Search Configuration (Optional)
# ===========================================
# Tavily is a search engine optimized for AI applications.
# If not configured, the tavily_search tool will be automatically disabled.
# Get your API key at: https://tavily.com
# TAVILY_API_KEY=your-tavily-api-key-here
